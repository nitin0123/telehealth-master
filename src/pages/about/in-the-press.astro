---
import PageLayout from '../../layouts/PageLayout.astro';
import { pressFeatures } from '../../data/content';
---
<PageLayout
  section="About"
  kicker="About"
  title="In the press"
  metaTitle="In The Press | ResetWell Plus"
  description="Press coverage and media features for ResetWell Plus, India's expert-led platform for perimenopause and menopause care."
  lede="Coverage and recognition for our work in women's midlife health."
>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5">
    {pressFeatures.map((p, i) => (
      <a
        href={p.href}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative flex flex-col rounded-4xl overflow-hidden bg-white border border-sand shadow-sm reveal
               transition-all duration-300 ease-out will-change-transform
               hover:-translate-y-2 hover:shadow-2xl hover:shadow-ever/20 hover:border-clay/40"
        style={`--reveal-delay:${(i % 3) * 70}ms`}
      >
        <!-- thumbnail with zoom + shine sweep, or branded fallback -->
        <div class="relative overflow-hidden">
          {p.img ? (
            <img src={p.img} alt={`${p.publication}: ${p.title}`} loading="lazy" class="aspect-[16/9] w-full object-cover transition-transform duration-500 ease-out group-hover:scale-110" />
          ) : (
            <div class="aspect-[16/9] w-full grid place-items-center bg-ever transition-transform duration-500 ease-out group-hover:scale-110">
              <span class="font-serif text-2xl text-cream/90">{p.publication}</span>
            </div>
          )}
          <div class="pointer-events-none absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-out bg-gradient-to-r from-transparent via-white/40 to-transparent"></div>
        </div>

        <!-- publication + headline + date -->
        <div class="relative flex flex-1 flex-col p-5">
          <p class="eyebrow uppercase text-xs font-semibold text-clay">{p.publication}{p.date ? ` · ${p.date}` : ''}</p>
          <h3 class="mt-2 font-serif text-lg text-ever group-hover:text-clay transition-colors duration-200">{p.title}</h3>
          <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-clay">
            Read article
            <span class="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
          </span>
        </div>
      </a>
    ))}
  </div>

  <p class="mt-10 text-center text-stone reveal">
    For press enquiries, <a href="/contact" class="font-semibold text-ever underline decoration-clay/40 underline-offset-4 hover:decoration-clay transition">get in touch</a>.
  </p>
</PageLayout>
