---
import PageLayout from '../../layouts/PageLayout.astro';
---
<PageLayout
  section="About"
  sectionHref="/about"
  kicker="About"
  title="Swati Singh"
  metaTitle="Swati Singh | ResetWell Plus"
  description="Swati Singh, co-founder of ResetWell Plus: author, menopause educator, speaker and women's wellness advocate."
  lede="Author, menopause educator, speaker & women's wellness advocate."
>
  <div class="grid md:grid-cols-[auto_1fr] gap-8 lg:gap-10 items-start">
    <img
      src="/swati.jpeg"
      alt="Swati Singh"
      width="224"
      height="224"
      loading="lazy"
      class="w-44 h-44 md:w-56 md:h-56 rounded-4xl object-cover object-center border-4 border-sand shadow-sm"
    />
    <div class="prose-none text-stone text-lg leading-relaxed space-y-4 reveal">
      <!-- BIO PLACEHOLDER: replace with Swati's bio text when provided. -->
      <p>Bio coming soon.</p>
    </div>
  </div>
</PageLayout>
