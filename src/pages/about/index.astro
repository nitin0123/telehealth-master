---
import PageLayout from '../../layouts/PageLayout.astro';
import { BOOK_HREF } from '../../data/nav';

const founders = [
  { name: 'Swati Singh', role: 'Menopause educator, speaker & women\'s wellness advocate' },
  { name: 'Reshma Tiwari', role: 'Menopause educator, speaker & women\'s wellness advocate' },
];
---
<PageLayout
  section="About"
  sectionHref="/about/our-story"
  kicker="About"
  title="About Us"
  metaTitle="About ResetWell Plus | Women's Midlife & Menopause Wellness"
  description="ResetWell Plus is a women's wellness platform for menopause and midlife, created by Swati Singh and Reshma Tiwari to bring clarity, compassion and community to women everywhere."
  keywords="about ResetWell Plus, menopause wellness India, women's midlife community"
  lede="A space created by women who have walked the journey themselves, determined to make sure no one else walks it alone."
>
  <!-- Founders -->
  <div class="grid sm:grid-cols-2 gap-5 mb-14">
    {founders.map((f) => (
      <article class="bg-white border border-sand rounded-4xl p-6 flex items-center gap-5 reveal">
        <div class="w-24 h-24 shrink-0 rounded-full bg-gradient-to-br from-peach to-sage/40 grid place-items-center text-ever/30 font-serif text-sm">Photo</div>
        <div>
          <h2 class="font-serif text-2xl text-ever">{f.name}</h2>
          <p class="text-stone mt-1">{f.role}</p>
        </div>
      </article>
    ))}
  </div>

  <!-- Our Story -->
  <div class="bg-white border border-sand rounded-5xl p-8 lg:p-12 reveal">
    <p class="eyebrow uppercase text-sm font-semibold text-clay mb-4">Our Story</p>
    <div class="space-y-5 text-stone text-lg leading-relaxed max-w-2xl">
      <p class="font-serif text-2xl text-ever">Welcome to ResetWell Plus, crafted with care for women's wellness.</p>
      <p>
        A space created by women who have walked the journey themselves and are determined to make sure no one else walks
        it alone. We are Swati and Reshma, menopause educators, motivational speakers and women's wellness advocates.
        After experiencing firsthand how confusing, isolating, and overlooked this stage of life can be, we made it our
        mission to bring clarity, compassion, and community to women everywhere.
      </p>
      <p>
        At ResetWell Plus, we break the silence. We replace fear with knowledge. We replace confusion with confidence.
        And we replace isolation with a supportive sisterhood.
      </p>
      <p>
        Through empowering events, honest conversations, expert interviews, and practical guidance, we help women
        understand their bodies, and embrace and rediscover the strength and brilliance they already possess.
      </p>
      <a href={BOOK_HREF} class="mt-3 btn-primary">Book a Consultation</a>
    </div>
  </div>
</PageLayout>
