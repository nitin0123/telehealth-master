---
import BaseLayout from '../layouts/BaseLayout.astro';
import { nav } from '../data/nav';
// A few helpful links to guide people back into the site.
const quick = [
  { label: 'Take the Symptom Checker', href: '/understand-your-symptoms/symptom-checker/' },
  { label: 'How it works', href: '/get-care/how-it-works/' },
  { label: 'Pricing', href: '/get-care/pricing/' },
];
---
<BaseLayout title="Page not found | ResetWell Plus" description="The page you were looking for couldn't be found." noindex={true}>
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-24 right-0 w-96 h-96 rounded-full bg-peach/60 blur-3xl"></div>
      <div class="absolute bottom-0 -left-24 w-96 h-96 rounded-full bg-sage/50 blur-3xl"></div>
    </div>

    <div class="max-w-3xl mx-auto px-5 lg:px-8 py-10 sm:py-14 lg:py-20 text-center">
      <p class="font-serif text-[6rem] sm:text-[9rem] leading-none text-ever reveal">404</p>
      <h1 class="mt-2 font-serif text-3xl sm:text-4xl text-ever reveal" style="--reveal-delay:60ms">We can't find that page.</h1>
      <p class="mt-4 text-lg text-stone max-w-md mx-auto reveal" style="--reveal-delay:120ms">
        The link may be broken, or the page may have moved. Let's get you back on track.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center reveal" style="--reveal-delay:180ms">
        <a href="/" class="btn-primary">Back to home</a>
        <a href="/community/faqs/" class="btn-ghost">Browse FAQs</a>
      </div>

      <div class="mt-10 reveal" style="--reveal-delay:240ms">
        <p class="eyebrow uppercase text-xs font-semibold text-clay mb-4">Popular pages</p>
        <div class="flex flex-wrap justify-center gap-2">
          {quick.map((q) => (
            <a href={q.href} class="rounded-full border border-sand bg-white px-4 py-2 text-sm text-ink hover:border-clay hover:text-clay transition">{q.label}</a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
