---
import PageLayout from '../layouts/PageLayout.astro';
import { CONTACT } from '../data/seo';

// Social icons (currentColor, so they inherit the link's hover colour).
const igIcon = '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>';
const fbIcon = '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.53-1.5H17V3.6c-.28-.04-1.25-.12-2.37-.12-2.35 0-3.96 1.43-3.96 4.07v2.27H8v3.1h2.67V21h2.83z"/></svg>';
const liIcon = '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 8.5H4.06V20h2.88V8.5zM5.5 7.2A1.7 1.7 0 105.5 3.8a1.7 1.7 0 000 3.4zM20 20h-2.88v-5.7c0-1.36-.49-2.29-1.71-2.29-.93 0-1.49.63-1.73 1.24-.09.22-.11.52-.11.82V20H10.7s.04-9.36 0-10.32h2.88v1.46c.38-.59 1.07-1.43 2.6-1.43 1.9 0 3.32 1.24 3.32 3.9V20z"/></svg>';
const ytIcon = '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M23 12s0-3.1-.4-4.6a2.5 2.5 0 0 0-1.75-1.75C19.3 5.25 12 5.25 12 5.25s-7.3 0-8.85.4A2.5 2.5 0 0 0 1.4 7.4C1 8.9 1 12 1 12s0 3.1.4 4.6a2.5 2.5 0 0 0 1.75 1.75c1.55.4 8.85.4 8.85.4s7.3 0 8.85-.4a2.5 2.5 0 0 0 1.75-1.75C23 15.1 23 12 23 12zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>';
---
<PageLayout
  section="About"
  sectionHref="/about/our-story/"
  kicker="Contact"
  title="Contact us"
  metaTitle="Contact ResetWell Plus | Menopause Care in India"
  description="Get in touch with ResetWell Plus. Questions about perimenopause and menopause care, consultations, events or partnerships, our team is here to help."
  keywords="contact ResetWell Plus, menopause care India contact"
  lede="Questions about your symptoms, consultations, events or partnerships? Send us a message and our care team will get back to you."
>
  <div class="grid lg:grid-cols-5 gap-8">
    <!-- Form -->
    <div class="lg:col-span-3">
      <div class="bg-white border border-sand rounded-5xl p-6 lg:p-10 shadow-sm reveal">
        <h2 class="font-serif text-3xl text-ever mb-6">Send us a message</h2>
        <form data-contact-form novalidate>
          <!-- Honeypot: hidden from users; bots that fill it are silently dropped -->
          <div class="hidden" aria-hidden="true">
            <label>Company<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
          </div>
          <div class="mb-4">
            <label class="block text-sm text-stone mb-1" for="cf-name">Name <span class="text-clay">*</span></label>
            <input id="cf-name" name="name" required placeholder="Your full name"
              class="w-full rounded-2xl border border-sand bg-cream px-4 py-3 focus:outline-none focus:ring-2 focus:ring-clay/40" />
          </div>
          <div class="mb-4">
            <label class="block text-sm text-stone mb-1" for="cf-email">Email <span class="text-clay">*</span></label>
            <input id="cf-email" name="email" type="email" required placeholder="your@email.com"
              class="w-full rounded-2xl border border-sand bg-cream px-4 py-3 focus:outline-none focus:ring-2 focus:ring-clay/40" />
          </div>
          <div class="mb-4">
            <label class="block text-sm text-stone mb-1" for="cf-phone">Phone <span class="text-clay">*</span></label>
            <input id="cf-phone" name="phone" type="tel" required placeholder="10-digit mobile number"
              class="w-full rounded-2xl border border-sand bg-cream px-4 py-3 focus:outline-none focus:ring-2 focus:ring-clay/40" />
          </div>
          <div class="mb-4">
            <label class="block text-sm text-stone mb-1" for="cf-message">Message <span class="text-clay">*</span></label>
            <textarea id="cf-message" name="message" required rows="5" placeholder="Tell us about yourself and what you're looking for..."
              class="w-full rounded-2xl border border-sand bg-cream px-4 py-3 focus:outline-none focus:ring-2 focus:ring-clay/40"></textarea>
          </div>

          <!-- Security check (simple maths captcha, anti-spam) -->
          <div class="mb-6">
            <label class="flex items-center gap-2 text-sm text-stone mb-1" for="cf-captcha">
              <svg class="w-4 h-4 text-sage" viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v6c0 4-3 6.5-7 9-4-2.5-7-5-7-9V6l7-3z" stroke="currentColor" stroke-width="1.6"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Security Check <span class="text-clay">*</span>
            </label>
            <p class="text-sm text-ink mb-2">What is <span data-captcha-q>6 + 8</span>?</p>
            <input id="cf-captcha" name="captcha" inputmode="numeric" required placeholder="Your answer"
              class="w-full rounded-2xl border border-sand bg-cream px-4 py-3 focus:outline-none focus:ring-2 focus:ring-clay/40" />
            <p data-captcha-err class="hidden mt-2 text-sm text-clay">That answer isn't right, please try again.</p>
          </div>

          <button class="w-full sm:w-auto rounded-full bg-clay hover:bg-claydk text-white font-semibold px-8 py-3.5 transition disabled:opacity-60 disabled:cursor-not-allowed">Send Message</button>
          <p data-contact-err class="hidden mt-3 text-sm text-clay"></p>
        </form>

        <div data-contact-success class="hidden text-center py-8">
          <h3 class="font-serif text-3xl text-ever mb-2">Message sent ✓</h3>
          <p class="text-stone">Thank you for reaching out. Our care team will get back to you within one working day.</p>
        </div>
      </div>
    </div>

    <!-- Contact details -->
    <aside class="lg:col-span-2 space-y-4">
      <div class="bg-sand/50 rounded-4xl p-6 reveal">
        <p class="eyebrow uppercase text-xs font-semibold text-clay mb-3">Reach us directly</p>
        <!-- Email/phone are base64-encoded and only decoded in the browser on
             click, so address-harvesting bots reading the HTML get nothing. -->
        <button
          data-reveal-contact
          data-email={Buffer.from(CONTACT.email).toString('base64')}
          data-phones={CONTACT.phones.map((p) => Buffer.from(p).toString('base64')).join(',')}
          aria-expanded="false"
          class="mt-2 inline-flex items-center gap-2 rounded-full bg-white border border-ever/20 hover:border-ever hover:bg-ever hover:text-cream text-ever font-semibold text-sm px-4 py-2 transition-colors"
        >
          <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
          Show contact details
        </button>
        <div data-reveal-out class="hidden mt-2 space-y-3"></div>
      </div>
      <div class="bg-sand/50 rounded-4xl p-6 reveal" style="--reveal-delay:80ms">
        <p class="eyebrow uppercase text-xs font-semibold text-clay mb-3">Connect</p>
        <div class="flex flex-wrap gap-2">
          <a href={CONTACT.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" title="Instagram" class="w-12 h-12 grid place-items-center rounded-full border border-sand bg-white text-ever hover:border-clay hover:text-clay transition"><Fragment set:html={igIcon} /></a>
          <a href={CONTACT.social.facebook} target="_blank" rel="noopener" aria-label="Facebook" title="Facebook" class="w-12 h-12 grid place-items-center rounded-full border border-sand bg-white text-ever hover:border-clay hover:text-clay transition"><Fragment set:html={fbIcon} /></a>
          <a href={CONTACT.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" title="LinkedIn" class="w-12 h-12 grid place-items-center rounded-full border border-sand bg-white text-ever hover:border-clay hover:text-clay transition"><Fragment set:html={liIcon} /></a>
          <a href={CONTACT.social.youtube} target="_blank" rel="noopener" aria-label="YouTube" title="YouTube" class="w-12 h-12 grid place-items-center rounded-full border border-sand bg-white text-ever hover:border-clay hover:text-clay transition"><Fragment set:html={ytIcon} /></a>
        </div>
      </div>
    </aside>
  </div>

  <script>
    import { contactSchema, firstError } from '../lib/schemas';

    document.querySelectorAll<HTMLFormElement>('[data-contact-form]').forEach((form) => {
      // Generate a fresh maths captcha each load
      const a = Math.floor(Math.random() * 8) + 2;
      const b = Math.floor(Math.random() * 8) + 2;
      const qEl = form.querySelector('[data-captcha-q]');
      if (qEl) qEl.textContent = `${a} + ${b}`;
      const captchaErr = form.querySelector('[data-captcha-err]');
      const submitErr = form.querySelector('[data-contact-err]');
      const btn = form.querySelector('button') as HTMLButtonElement | null;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!form.reportValidity()) return;
        const captcha = (form.elements.namedItem('captcha') as HTMLInputElement)?.value.trim();
        if (Number(captcha) !== a + b) {
          captchaErr?.classList.remove('hidden');
          return;
        }
        captchaErr?.classList.add('hidden');
        submitErr?.classList.add('hidden');

        const data = Object.fromEntries(new FormData(form).entries()) as Record<string, string>;
        delete data.captcha;

        const check = contactSchema.safeParse(data);
        if (!check.success) {
          if (submitErr) {
            submitErr.textContent = firstError(check.error);
            submitErr.classList.remove('hidden');
          }
          return;
        }

        const original = btn?.textContent ?? 'Send Message';
        if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          if (!res.ok) {
            const info = await res.json().catch(() => ({}));
            throw new Error(info.error || 'Something went wrong. Please try again.');
          }
          form.classList.add('hidden');
          form.parentElement?.querySelector('[data-contact-success]')?.classList.remove('hidden');
        } catch (err) {
          if (submitErr) {
            submitErr.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
            submitErr.classList.remove('hidden');
          }
          if (btn) { btn.disabled = false; btn.textContent = original; }
        }
      });
    });
  </script>

  <!-- Decode the obfuscated contact details on demand -->
  <script is:inline>
    document.querySelectorAll('[data-reveal-contact]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var out = btn.parentElement.querySelector('[data-reveal-out]');
        if (!out) return;
        var email = atob(btn.dataset.email);
        var phones = btn.dataset.phones.split(',').map(function (p) { return atob(p); });

        var emailWrap = document.createElement('div');
        var emailLabel = document.createElement('p');
        emailLabel.className = 'text-stone text-sm';
        emailLabel.textContent = 'Email';
        var emailLink = document.createElement('a');
        emailLink.href = 'mailto:' + email;
        emailLink.className = 'font-medium text-ever hover:text-clay';
        emailLink.textContent = email;
        emailWrap.appendChild(emailLabel);
        emailWrap.appendChild(emailLink);
        out.appendChild(emailWrap);

        var phoneWrap = document.createElement('div');
        var phoneLabel = document.createElement('p');
        phoneLabel.className = 'text-stone text-sm';
        phoneLabel.textContent = 'Phone';
        phoneWrap.appendChild(phoneLabel);
        phones.forEach(function (p) {
          var link = document.createElement('a');
          link.href = 'tel:+' + p.replace(/\D/g, '');
          link.className = 'block font-medium text-ever hover:text-clay';
          link.textContent = p;
          phoneWrap.appendChild(link);
        });
        out.appendChild(phoneWrap);

        out.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        btn.remove();
      });
    });
  </script>
</PageLayout>
