---
import PageLayout from '../layouts/PageLayout.astro';
// PLACEHOLDER: replace with a lawyer-reviewed privacy policy before launch.
---
<PageLayout
  section="About"
  sectionHref="/about/our-story"
  kicker="Legal"
  title="Privacy Policy"
  metaTitle="Privacy Policy | ResetWell Plus"
  description="How ResetWell Plus collects, uses and protects your personal and health information."
  noindex={true}
>
  <div class="bg-white border border-sand rounded-5xl p-8 lg:p-12 reveal">
    <p class="text-stone bg-peach/40 border border-sand rounded-2xl px-4 py-3 text-sm mb-6">
      Placeholder content. Have this reviewed by legal counsel and ensure it complies with India's DPDP Act and any
      other jurisdictions you operate in before publishing.
    </p>
    <div class="space-y-4 text-stone leading-relaxed max-w-2xl">
      <p>ResetWell Plus respects your privacy. This policy explains what information we collect, how we use it, and the choices you have.</p>
      <h2 class="font-serif text-2xl text-ever pt-2">Information we collect</h2>
      <p>Contact details you provide, symptom and health information you share during assessments or consultations, and basic usage data.</p>
      <h2 class="font-serif text-2xl text-ever pt-2">How we use it</h2>
      <p>To provide care, respond to enquiries, improve our services, and communicate with you. We do not sell your personal data.</p>
      <h2 class="font-serif text-2xl text-ever pt-2">Your choices</h2>
      <p>You can request access to, correction of, or deletion of your data at any time by contacting us.</p>
    </div>
  </div>
</PageLayout>
