---
import PageLayout from '../../layouts/PageLayout.astro';
const articles = [
  ['Sleep & night sweats', 'Why menopause disrupts sleep, and what actually helps.', 'Sleep'],
  ['Understanding HRT', 'Benefits, risks and the questions to ask your clinician.', 'Treatment'],
  ['Midlife nutrition', 'Eating for energy, metabolism and bone health.', 'Nutrition'],
  ['Mood & brain fog', 'The hormonal roots of anxiety, low mood and forgetfulness.', 'Mind'],
  ['Strength & bones', 'Protecting bone density and muscle in your 40s and 50s.', 'Body'],
  ['Sexual wellness', 'Common changes, and the solutions no one talks about.', 'Wellness'],
];
---
<PageLayout
  section="Understand Your Symptoms"
  kicker="Understand Your Symptoms"
  title="Knowledge Centre"
  metaTitle="Menopause & Perimenopause Knowledge Centre (India) | ResetWell Plus"
  description="Evidence-based articles and guides on perimenopause and menopause for women in India: sleep, HRT, nutrition, mood, joint pain and more. Reviewed by our medical team."
  keywords="menopause information India, perimenopause guide India, is HRT safe in India, menopause joint pain India"
  lede="Evidence-based articles and guides for women in India, reviewed by our medical team."
>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {articles.map(([h, p, tag]) => (
      <a href="#" class="group bg-white border border-sand rounded-4xl overflow-hidden hover:shadow-xl hover:shadow-ever/5 transition reveal">
        <div class="aspect-[16/9] bg-gradient-to-br from-peach to-sage/40 grid place-items-center text-ever/30 font-serif">Photo</div>
        <div class="p-6">
          <span class="eyebrow uppercase text-xs font-semibold text-clay">{tag}</span>
          <h2 class="font-serif text-2xl text-ever mt-1">{h}</h2>
          <p class="mt-2 text-stone text-base leading-relaxed">{p}</p>
        </div>
      </a>
    ))}
  </div>
</PageLayout>
