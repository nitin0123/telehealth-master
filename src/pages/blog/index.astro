---
// Blog index: lists every published post in src/content/blog, newest first.
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const fmt = (d: Date) => d.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' });
const readMins = (body: string) => Math.max(1, Math.round(body.split(/\s+/).length / 220));
---

<PageLayout
  title="The ResetWell Blog"
  lede="Straight talk on perimenopause, menopause, and midlife health: what's happening in your body, and what you can actually do about it."
  description="Articles on perimenopause and menopause symptoms, treatment options, and midlife wellness from the ResetWell Plus team."
  keywords="menopause blog India, perimenopause symptoms, menopause articles"
>
  <div class="grid gap-4 lg:gap-5 sm:grid-cols-2">
    {posts.map((post, i) => (
      <a
        href={`/blog/${post.slug}/`}
        class="group relative flex flex-col rounded-4xl overflow-hidden bg-white border border-sand shadow-sm reveal
               transition-all duration-300 ease-out will-change-transform
               hover:-translate-y-2 hover:shadow-2xl hover:shadow-ever/20 hover:border-clay/40"
        style={`--reveal-delay:${(i % 2) * 70}ms`}
      >
        <!-- brand gradient band with shine sweep (canonical card hover) -->
        <div class="relative overflow-hidden h-2.5 bg-gradient-to-r from-ever via-clay to-sage">
          <div class="pointer-events-none absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-out bg-gradient-to-r from-transparent via-white/40 to-transparent"></div>
        </div>

        <div class="flex flex-col flex-1 p-6 sm:p-7">
          <p class="text-xs text-stone">{fmt(post.data.publishedAt)} · {readMins(post.body)} min read</p>
          <h2 class="mt-2.5 font-serif text-xl lg:text-2xl leading-snug text-ever group-hover:text-clay transition-colors duration-200">
            {post.data.title}
          </h2>
          {post.data.subtitle && <p class="mt-1 text-sm text-stone italic">{post.data.subtitle}</p>}
          <p class="mt-3 text-sm text-stone flex-1">{post.data.synopsis}</p>
          <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-clay">
            Read the post
            <span class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" aria-hidden="true">→</span>
          </span>
        </div>
      </a>
    ))}
  </div>
</PageLayout>
