---
import PageLayout from '../../layouts/PageLayout.astro';
---
<PageLayout
  section="Get Care"
  kicker="Get Care"
  title="Meet our specialists"
  metaTitle="Menopause Specialists & Experts in India | ResetWell Plus"
  description="ResetWell Plus is building a panel of menopause specialists in India: gynaecologists, endocrinologists and nutritionists who specialise in women's midlife health. Introductions coming soon."
  keywords="menopause expert India, menopause specialist India, gynaecologist menopause India"
  lede="Clinicians who specialise in women's midlife health, so you feel heard from your first visit."
>
  <div class="bg-ever text-cream rounded-5xl p-8 lg:p-12 text-center reveal">
    <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-sm font-semibold">
      <span class="w-2 h-2 rounded-full bg-clay animate-pulse"></span> Coming soon
    </span>
    <h2 class="mt-5 font-serif text-3xl lg:text-4xl">Our specialist panel is on its way.</h2>
    <p class="mt-3 text-cream/70 max-w-xl mx-auto text-lg">
      We're partnering with leading menopause clinicians across India. Stay tuned, we'll introduce the team here soon.
      In the meantime, join our community to be the first to know.
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href="/community/join" class="inline-flex items-center rounded-full bg-cream text-ever font-semibold px-6 py-3 hover:bg-white transition">Join the community</a>
      <a href="/contact" class="inline-flex items-center rounded-full border border-cream/30 text-cream font-semibold px-6 py-3 hover:bg-white/10 transition">Contact us</a>
    </div>
  </div>
</PageLayout>
