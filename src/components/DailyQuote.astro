---
// "Today's Reset": one wellness quote per day, picked by day of year in IST so
// every visitor sees the same quote on a given date. Pages are prerendered, so
// the quote baked in at build time is only a fallback; the script below
// recomputes it on the visitor's device, meaning the quote rotates daily
// without a rebuild.
import { quotes } from '../data/quotes';
import { SITE } from '../data/seo';

// Days elapsed since the Unix epoch, in IST. Unlike day-of-year this never
// resets, so consecutive days always step through the list in order and any
// 300-day stretch shows all 300 quotes with no repeats.
const IST_OFFSET_MS = 5.5 * 60 * 60 * 1000;
const DAY_MS = 24 * 60 * 60 * 1000;
const istDay = Math.floor((Date.now() + IST_OFFSET_MS) / DAY_MS);
const quote = quotes[istDay % quotes.length];
const shareText = `Today's Reset from ${SITE.name}:\n\n"${quote}"\n\nA new thought for women in midlife, every day: ${SITE.url}`;
const shareHref = `https://wa.me/?text=${encodeURIComponent(shareText)}`;
---
<section class="max-w-7xl mx-auto px-5 lg:px-8 pb-8 lg:pb-10">
  <div class="relative overflow-hidden rounded-5xl bg-gradient-to-br from-peach via-sand to-sage/60 px-6 py-6 lg:px-12 lg:py-8 text-center reveal">
    <!-- Oversized decorative quote mark -->
    <span class="absolute -top-4 left-4 lg:left-8 font-serif text-[6rem] leading-none text-clay/15 select-none" aria-hidden="true">&ldquo;</span>
    <p class="eyebrow uppercase text-sm font-semibold text-clay mb-3">Today&rsquo;s Reset</p>
    <blockquote data-daily-quote class="relative font-serif text-2xl lg:text-3xl text-ever leading-snug max-w-5xl mx-auto">
      {quote}
    </blockquote>
    <p class="mt-3 text-sm text-stone">A new thought for women in midlife, every day.</p>
    <a
      data-daily-quote-share
      href={shareHref}
      target="_blank"
      rel="noopener"
      class="mt-4 inline-flex items-center gap-2 rounded-full bg-white/80 border border-ever/15 px-4 py-2 text-sm font-semibold text-ever hover:bg-ever hover:border-ever hover:text-cream transition-colors"
    >
      <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Share on WhatsApp
    </a>
  </div>
</section>

<script>
  import { quotes } from '../data/quotes';

  // Same days-since-epoch (IST) formula as the server fallback above.
  const istDay = Math.floor((Date.now() + 5.5 * 60 * 60 * 1000) / 86400000);
  const quote = quotes[istDay % quotes.length];
  const el = document.querySelector('[data-daily-quote]');
  if (el && quote) el.textContent = quote;

  // Keep the WhatsApp share link in sync with the quote shown today.
  const share = document.querySelector('[data-daily-quote-share]');
  if (share && quote) {
    const text = `Today's Reset from ResetWell Plus:\n\n"${quote}"\n\nA new thought for women in midlife, every day: https://www.resetwellplus.com`;
    share.setAttribute('href', `https://wa.me/?text=${encodeURIComponent(text)}`);
  }
</script>
