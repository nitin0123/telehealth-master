---
import { events, type EventItem } from '../data/content';
interface Props { filter?: string; }
const { filter } = Astro.props;
const list: EventItem[] = filter ? events.filter((e) => e.tag.includes(filter)) : events;
---
<div class="grid md:grid-cols-2 gap-6">
  {list.map((e) => (
    <article class="bg-white border border-sand rounded-4xl p-6 reveal">
      <span class="eyebrow uppercase text-xs font-semibold text-clay">{e.tag}</span>
      <h2 class="font-serif text-2xl text-ever mt-2">{e.title}</h2>
      <p class="text-sm text-stone mt-1">{e.meta}</p>
    </article>
  ))}
</div>
