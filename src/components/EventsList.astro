---
import { events, type EventItem } from '../data/content';
interface Props { filter?: string; }
const { filter } = Astro.props;
const list: EventItem[] = filter ? events.filter((e) => e.tag.includes(filter)) : events;
---
{list.length === 0 ? (
  <div class="bg-white border border-sand rounded-4xl p-8 lg:p-10 text-center reveal">
    <span class="eyebrow uppercase text-xs font-semibold text-clay">Coming soon</span>
    <h2 class="font-serif text-2xl text-ever mt-2">New events are on the way</h2>
    <p class="text-sm text-stone mt-2 max-w-md mx-auto">We're lining up our next live sessions. Join the community to hear about dates first, or browse our on-demand library in the meantime.</p>
    <div class="mt-6 flex flex-col sm:flex-row justify-center gap-3">
      <a href="/community/join" class="btn-primary px-7 py-3.5">Get notified</a>
      <a href="/events/on-demand" class="btn-ghost px-7 py-3.5">Watch on demand</a>
    </div>
  </div>
) : (
  <div class="grid md:grid-cols-2 gap-6">
    {list.map((e) => (
      <article class="bg-white border border-sand rounded-4xl p-6 reveal">
        <span class="eyebrow uppercase text-xs font-semibold text-clay">{e.tag}</span>
        <h2 class="font-serif text-2xl text-ever mt-2">{e.title}</h2>
        <p class="text-sm text-stone mt-1">{e.meta}</p>
      </article>
    ))}
  </div>
)}
