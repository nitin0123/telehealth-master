---
import { steps } from '../data/content';
import { BOOK_HREF } from '../data/nav';
---
<section class="bg-ever text-cream">
  <div class="max-w-7xl mx-auto px-5 lg:px-8 py-8 lg:py-10">
    <div class="text-center max-w-2xl mx-auto mb-6 reveal">
      <p class="eyebrow uppercase text-xs font-semibold text-sage mb-3">Easy as 1, 2, 3</p>
      <h2 class="font-serif text-3xl lg:text-5xl">Ready for relief?</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      {steps.map((s, i) => (
        <div class="bg-white/5 rounded-4xl p-6 transition-all duration-300 ease-out will-change-transform hover:-translate-y-1.5 hover:bg-white/10 reveal" style={`--reveal-delay:${i * 90}ms`}>
          <h3 class="font-serif text-2xl"><span class="text-sage">{s.n}.</span> {s.title}</h3>
          <p class="mt-3 text-cream/70 text-base leading-relaxed">{s.body}</p>
        </div>
      ))}
    </div>
    <div class="text-center mt-8">
      <a href={BOOK_HREF} class="inline-flex items-center rounded-full bg-clay hover:bg-claydk transition text-white font-semibold px-7 py-3.5">Book a Consultation</a>
    </div>
  </div>
</section>
