---
import { events } from '../data/content';
const featured = events.slice(0, 3);
---
<section class="max-w-7xl mx-auto px-5 lg:px-8 py-12 lg:py-16 grid lg:grid-cols-2 gap-8">
  <div class="reveal">
    <p class="eyebrow uppercase text-xs font-semibold text-clay mb-3">Events</p>
    <h2 class="font-serif text-3xl lg:text-4xl text-ever mb-6">Learn from the experts</h2>
    <div class="space-y-3">
      {featured.map((e) => (
        <a href="/events/upcoming" class="flex items-center justify-between bg-white border border-sand rounded-3xl p-5 hover:shadow-lg hover:shadow-ever/5 transition">
          <span>
            <span class="font-serif text-xl text-ever">{e.title}</span>
            <span class="block text-sm text-stone mt-0.5">{e.meta}</span>
          </span>
          <span class="text-clay text-xl">→</span>
        </a>
      ))}
    </div>
  </div>

  <div class="bg-gradient-to-br from-peach via-sand to-sage/60 rounded-5xl p-8 lg:p-10 flex flex-col justify-center reveal" style="--reveal-delay:100ms">
    <p class="eyebrow uppercase text-xs font-semibold text-clay mb-3">Community</p>
    <h2 class="font-serif text-3xl lg:text-4xl text-ever">Join the women's health revolution</h2>
    <p class="mt-3 text-ever/70">A private, moderated, judgement-free space to share what works, and feel a little less alone.</p>
    <form class="mt-6 flex flex-col sm:flex-row gap-3" data-join-form>
      <input type="email" name="email" required placeholder="you@example.com" class="flex-1 rounded-full px-5 py-3.5 bg-white focus:outline-none focus:ring-2 focus:ring-clay/40" />
      <button class="rounded-full bg-ever hover:bg-everdk transition text-cream font-semibold px-6 py-3.5">Join free</button>
    </form>
    <p data-join-msg class="mt-3 text-sm text-ever/70 hidden">Welcome in ✓ Check your inbox to confirm.</p>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-join-form]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      // TODO: POST to your backend / email provider here.
      form.classList.add('hidden');
      form.parentElement?.querySelector('[data-join-msg]')?.classList.remove('hidden');
    });
  });
</script>
