---
import { BOOK_HREF } from '../data/nav';
---
<section class="max-w-7xl mx-auto px-5 lg:px-8 py-10 lg:py-12">
  <div class="rounded-5xl bg-ever text-cream px-6 py-10 lg:py-12 text-center reveal">
    <p class="eyebrow uppercase text-xs font-semibold text-sage mb-3">The ResetWell Plus mission</p>
    <h2 class="font-serif text-4xl lg:text-5xl max-w-2xl mx-auto">The midlife care you deserve, starting today.</h2>
    <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
      <a href={BOOK_HREF} class="inline-flex justify-center items-center rounded-full bg-clay hover:bg-claydk transition text-white font-semibold px-8 py-4">Book a Consultation</a>
      <a href="/about/workplace-wellness/" class="inline-flex justify-center items-center rounded-full bg-cream/10 hover:bg-cream/20 transition text-cream font-semibold px-8 py-4">Partner With Us</a>
    </div>
  </div>
</section>
