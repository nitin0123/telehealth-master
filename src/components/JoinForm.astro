---
// Community join form. Persists the email via /api/subscribe (DB + Resend email).
---
<div class="max-w-md mx-auto bg-white border border-sand rounded-5xl p-8 reveal">
  <form data-join-form>
    <label class="block text-sm text-stone mb-1" for="join-email">Email address</label>
    <input id="join-email" name="email" type="email" required autocomplete="email" class="w-full rounded-2xl border border-sand bg-cream px-4 py-3 mb-4 focus:outline-none focus:ring-2 focus:ring-clay/40" />
    <!-- Honeypot: hidden from users, catches bots -->
    <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
    <button class="w-full rounded-full bg-clay hover:bg-claydk text-white font-semibold py-3.5 disabled:opacity-60">Join the Community</button>
    <p data-join-err class="hidden text-sm text-red-600 mt-3 text-center"></p>
    <p class="text-xs text-stone mt-3 text-center">Free · Private · Unsubscribe anytime</p>
  </form>
  <p data-join-msg class="hidden text-center text-ever font-serif text-2xl py-6">Welcome in ✓</p>
</div>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-join-form]').forEach((form) => {
    const errEl = form.querySelector('[data-join-err]');
    const btn = form.querySelector('button') as HTMLButtonElement | null;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;
      errEl?.classList.add('hidden');

      const data = Object.fromEntries(new FormData(form).entries()) as Record<string, string>;
      data.source = 'community-join';

      const original = btn?.textContent ?? 'Join the Community';
      if (btn) { btn.disabled = true; btn.textContent = 'Joining…'; }
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) {
          const info = await res.json().catch(() => ({}));
          throw new Error(info.error || 'Something went wrong. Please try again.');
        }
        form.classList.add('hidden');
        form.parentElement?.querySelector('[data-join-msg]')?.classList.remove('hidden');
      } catch (err) {
        if (errEl) {
          errEl.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
          errEl.classList.remove('hidden');
        }
        if (btn) { btn.disabled = false; btn.textContent = original; }
      }
    });
  });
</script>
