---
// 3.2 The Problem Strip — bold typography on a warm lavender gradient.
const figures = [
  { stat: '46.2 years', body: 'The average age Indian women reach menopause. Up to five years earlier than the global average.' },
  { stat: '4.73 years', body: 'The average time educated Indian women wait before seeking help for symptoms they are already experiencing.' },
  { stat: '80%', body: 'The proportion of Indian menopausal women experiencing joint pain and musculoskeletal symptoms.' },
];
---
<section class="bg-gradient-to-br from-peach via-sand to-sage/40">
  <div class="max-w-7xl mx-auto px-5 lg:px-8 py-12 lg:py-16">
    <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl text-ever leading-tight reveal">
      1 in 3 Indian women navigate perimenopause without a diagnosis. That ends here.
    </h2>

    <div class="mt-8 grid sm:grid-cols-3 gap-6">
      {figures.map((f, i) => (
        <div class="bg-white rounded-4xl p-7 lg:p-8 shadow-sm shadow-ever/5 border border-white/60 reveal" style={`--reveal-delay:${i * 90}ms`}>
          <p class="font-serif text-4xl lg:text-5xl text-clay">{f.stat}</p>
          <p class="mt-3 text-stone text-lg leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>

    <p class="mt-12 font-serif text-2xl lg:text-3xl text-ever reveal">
      Your aches are not imagined. They are hormonal.
    </p>
  </div>
</section>
