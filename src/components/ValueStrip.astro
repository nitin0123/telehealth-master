---
import { stats } from '../data/content';
---
<section class="bg-ever text-cream">
  <div class="max-w-7xl mx-auto px-5 lg:px-8 py-10 lg:py-14 grid lg:grid-cols-2 gap-8 items-center">
    <div class="reveal">
      <p class="eyebrow uppercase text-xs font-semibold text-sage mb-3">Relief within reach</p>
      <h2 class="font-serif text-3xl lg:text-4xl">Transparent care, one simple price.</h2>
      <p class="mt-3 text-cream/70 max-w-md">No insurance maze, no hidden fees. Pay directly for expert care, and know exactly what's included before you book.</p>
      <a href="/get-care/pricing" class="mt-6 inline-flex items-center rounded-full bg-cream text-ever font-semibold px-6 py-3 hover:bg-white transition">See Pricing</a>
    </div>
    <div class="grid grid-cols-2 gap-3">
      {stats.map((s, i) => (
        <div class="bg-white/10 rounded-2xl p-5 reveal" style={`--reveal-delay:${i * 70}ms`}>
          <p class="font-serif text-3xl">{s.value}</p>
          <p class="text-sm text-cream/70 mt-1">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
