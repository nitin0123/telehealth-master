---
import { nav } from '../data/nav';
import { CONTACT } from '../data/seo';
const cols = nav.filter((s) => ['Understand Your Symptoms', 'Get Care', 'Community', 'About'].includes(s.label));
const labelMap: Record<string, string> = {
  'Understand Your Symptoms': 'Symptoms',
  'Get Care': 'Care',
  'Community': 'Community',
  'About': 'About',
};
const year = new Date().getFullYear();

const igIcon = '<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>';
const liIcon = '<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 8.5H4.06V20h2.88V8.5zM5.5 7.2A1.7 1.7 0 105.5 3.8a1.7 1.7 0 000 3.4zM20 20h-2.88v-5.7c0-1.36-.49-2.29-1.71-2.29-.93 0-1.49.63-1.73 1.24-.09.22-.11.52-.11.82V20H10.7s.04-9.36 0-10.32h2.88v1.46c.38-.59 1.07-1.43 2.6-1.43 1.9 0 3.32 1.24 3.32 3.9V20z"/></svg>';
const ytIcon = '<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23 12s0-3.1-.4-4.6a2.5 2.5 0 0 0-1.75-1.75C19.3 5.25 12 5.25 12 5.25s-7.3 0-8.85.4A2.5 2.5 0 0 0 1.4 7.4C1 8.9 1 12 1 12s0 3.1.4 4.6a2.5 2.5 0 0 0 1.75 1.75c1.55.4 8.85.4 8.85.4s7.3 0 8.85-.4a2.5 2.5 0 0 0 1.75-1.75C23 15.1 23 12 23 12zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>';
const fbIcon = '<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.53-1.5H17V3.6c-.28-.04-1.25-.12-2.37-.12-2.35 0-3.96 1.43-3.96 4.07v2.27H8v3.1h2.67V21h2.83z"/></svg>';
---

<footer class="bg-sand text-ink/80">
  <!-- Link columns: accordion on mobile, static columns on sm+ -->
  <div class="max-w-7xl mx-auto px-5 lg:px-8 py-6 lg:py-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 sm:gap-8 text-sm">
    {cols.map((section, i) => (
      <div class="border-b border-ink/10 sm:border-0">
        <input type="checkbox" id={`foot-${i}`} class="peer sr-only" />
        <label
          for={`foot-${i}`}
          class="flex items-center justify-between gap-2 py-3 cursor-pointer select-none
                 sm:cursor-default sm:pointer-events-none sm:justify-center sm:py-0 sm:mb-3
                 peer-checked:[&_svg]:rotate-180"
        >
          <span class="text-clay eyebrow uppercase text-sm">{labelMap[section.label]}</span>
          <svg class="w-4 h-4 shrink-0 text-clay transition-transform duration-200 sm:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
        </label>
        <ul class="hidden peer-checked:block sm:block pb-3 sm:pb-0 text-center">
          {section.children.slice(0, 3).map((child) => (
            <li><a href={child.href} class="inline-block py-1 hover:text-clay transition">{child.label.replace(' (₹)', '')}</a></li>
          ))}
          {section.label === 'About' && <li><a href="/contact" class="inline-block py-1 hover:text-clay transition">Contact us</a></li>}
        </ul>
      </div>
    ))}
  </div>

  <!-- Bottom bar: socials + legal on as few lines as possible -->
  <div class="border-t border-ink/10">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-4 flex flex-col gap-3 items-center text-sm text-stone">
      <div class="flex flex-wrap items-center justify-center gap-2.5">
        <a href={CONTACT.social.linkedin} class="inline-flex items-center gap-1.5 rounded-full bg-white border border-sand hover:border-clay hover:text-clay transition px-3.5 py-1.5 text-ever"><Fragment set:html={liIcon} />{CONTACT.social.linkedinHandle}</a>
        <a href={CONTACT.social.instagram} class="inline-flex items-center gap-1.5 rounded-full bg-white border border-sand hover:border-clay hover:text-clay transition px-3.5 py-1.5 text-ever"><Fragment set:html={igIcon} />{CONTACT.social.instagramHandle}</a>
        <a href={CONTACT.social.facebook} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full bg-white border border-sand hover:border-clay hover:text-clay transition px-3.5 py-1.5 text-ever"><Fragment set:html={fbIcon} />Facebook</a>
        <a href={CONTACT.social.youtube} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full bg-white border border-sand hover:border-clay hover:text-clay transition px-3.5 py-1.5 text-ever"><Fragment set:html={ytIcon} />YouTube</a>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-x-2.5 gap-y-1 text-center text-xs">
        <span>© {year} ResetWell Plus LLC</span>
        <span class="text-stone/40">·</span>
        <span>ResetWell Plus Pvt. Ltd.</span>
        <span class="text-stone/40">·</span>
        <a href="/privacy-policy" class="hover:text-clay transition">Privacy Policy</a>
        <span class="text-stone/40">·</span>
        <a href="/terms" class="hover:text-clay transition">Terms of Use</a>
        <span class="text-stone/40">·</span>
        <a href="/disclaimer" class="hover:text-clay transition">Medical Disclaimer</a>
        <!-- Unhidden by Analytics.astro when tracking is configured -->
        <span data-cookie-prefs-wrap class="hidden">
          <span class="text-stone/40">·</span>
          <a href="#" data-cookie-prefs class="hover:text-clay transition">Cookie Preferences</a>
        </span>
      </div>
    </div>
  </div>
</footer>
