---
import { nav } from '../data/nav';
import { CONTACT } from '../data/seo';
const cols = nav.filter((s) => ['Understand Your Symptoms', 'Get Care', 'Community', 'About'].includes(s.label));
const labelMap: Record<string, string> = {
  'Understand Your Symptoms': 'Symptoms',
  'Get Care': 'Care',
  'Community': 'Community',
  'About': 'About',
};
const year = new Date().getFullYear();

const igIcon = '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>';
const liIcon = '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 8.5H4.06V20h2.88V8.5zM5.5 7.2A1.7 1.7 0 105.5 3.8a1.7 1.7 0 000 3.4zM20 20h-2.88v-5.7c0-1.36-.49-2.29-1.71-2.29-.93 0-1.49.63-1.73 1.24-.09.22-.11.52-.11.82V20H10.7s.04-9.36 0-10.32h2.88v1.46c.38-.59 1.07-1.43 2.6-1.43 1.9 0 3.32 1.24 3.32 3.9V20z"/></svg>';
const waIcon = '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none"><path d="M3 21l1.6-4A8 8 0 1 1 8 18.8L3 21z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>';
---

<footer class="bg-sand text-ink/80">
  <!-- Link columns + contact -->
  <div class="max-w-7xl mx-auto px-5 lg:px-8 py-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-8 text-base text-center">
    {cols.map((section) => (
      <div>
        <p class="text-clay eyebrow uppercase text-sm mb-4">{labelMap[section.label]}</p>
        <ul class="space-y-1">
          {section.children.slice(0, 3).map((child) => (
            <li><a href={child.href} class="inline-block py-1.5 hover:text-clay transition">{child.label.replace(' (₹)', '')}</a></li>
          ))}
          {section.label === 'About' && <li><a href="/contact" class="inline-block py-1.5 hover:text-clay transition">Contact us</a></li>}
        </ul>
      </div>
    ))}
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-ink/10">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-6 flex flex-col gap-4 items-center text-sm text-stone">
      <!-- Social links, centered -->
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href={CONTACT.social.linkedin} class="inline-flex items-center gap-1.5 rounded-full bg-white border border-sand hover:border-clay hover:text-clay transition px-3.5 py-1.5 text-ever"><Fragment set:html={liIcon} />{CONTACT.social.linkedinHandle}</a>
        <a href={CONTACT.social.instagram} class="inline-flex items-center gap-1.5 rounded-full bg-white border border-sand hover:border-clay hover:text-clay transition px-3.5 py-1.5 text-ever"><Fragment set:html={igIcon} />{CONTACT.social.instagramHandle}</a>
        <a href={CONTACT.social.whatsapp} class="inline-flex items-center gap-1.5 rounded-full bg-white border border-sand hover:border-clay hover:text-clay transition px-3.5 py-1.5 text-ever"><Fragment set:html={waIcon} />WhatsApp</a>
      </div>
      <!-- Copyright + legal entities on their own line -->
      <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-center">
        <span>© {year} ResetWell Plus LLC</span>
        <span class="text-stone/40">·</span>
        <span>ResetWell Plus Pvt. Ltd.</span>
      </div>
      <div class="flex flex-wrap justify-center items-center gap-x-3 gap-y-1">
        <a href="/privacy-policy" class="inline-block py-1 hover:text-clay transition">Privacy Policy</a>
        <span class="text-stone/40">|</span>
        <a href="/terms" class="inline-block py-1 hover:text-clay transition">Terms of Use</a>
        <span class="text-stone/40">|</span>
        <a href="/disclaimer" class="inline-block py-1 hover:text-clay transition">Medical Disclaimer</a>
      </div>
    </div>
  </div>
</footer>
