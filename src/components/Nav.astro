---
import { nav, BOOK_HREF } from '../data/nav';
import { WORDMARK } from '../data/seo';
import Brand from './Brand.astro';
const chevron = `<svg class="nav-chevron w-3 h-3 mt-0.5" viewBox="0 0 12 12" fill="none"><path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`;
---

<header class="sticky top-0 z-50 bg-cream/90 backdrop-blur border-b border-sand">
  <nav class="max-w-7xl mx-auto px-5 lg:px-8 flex items-center justify-between h-16 lg:h-20">
    <a href="/" aria-label={`${WORDMARK} home`} class="flex items-center shrink-0">
      <img src="/logo.png" alt={WORDMARK} width="56" height="56" decoding="async" class="h-12 lg:h-14 w-auto rounded-full"
        onerror="this.style.display='none';document.getElementById('brandFallback')?.style.setProperty('display','inline-block')" />
      <span id="brandFallback" style="display:none"><Brand class="text-2xl lg:text-[1.7rem]" /></span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-6 xl:gap-7 text-[15px] font-medium tracking-wide text-ink/80">
      <li><a href="/" class="hover:text-clay transition">Home</a></li>
      {nav.map((section) => (
        <li class="nav-item relative">
          <button class="nav-trigger relative flex items-center gap-1 hover:text-clay transition" aria-haspopup="true">
            {section.shortLabel ?? section.label}
            <Fragment set:html={chevron} />
          </button>
          <div class="nav-panel absolute left-0 top-full pt-3">
            <div class="relative w-72 bg-white/95 backdrop-blur rounded-3xl shadow-2xl shadow-ever/15 ring-1 ring-sand p-2">
              <span class="absolute left-7 -top-1.5 w-3 h-3 rotate-45 bg-white border-l border-t border-sand"></span>
              {section.children.map((child, i) => (
                <a
                  href={child.href}
                  class="nav-link group/item relative flex items-center gap-3 px-4 py-3 rounded-2xl hover:bg-peach/40 transition"
                  style={`--i:${i}`}
                >
                  <span class="flex-1">
                    <span class="block font-medium text-ink group-hover/item:text-clay transition-colors">{child.label}</span>
                    {child.blurb && <span class="block text-xs text-stone">{child.blurb}</span>}
                  </span>
                  <span class="text-clay opacity-0 -translate-x-1 group-hover/item:opacity-100 group-hover/item:translate-x-0 transition-all duration-200" aria-hidden="true">→</span>
                </a>
              ))}
            </div>
          </div>
        </li>
      ))}
      <li><a href="/book" class="hover:text-clay transition">The Book</a></li>
      <li><a href="/contact" class="hover:text-clay transition">Contact Us</a></li>
    </ul>

    <!-- Persistent CTA + mobile toggle -->
    <div class="flex items-center gap-3">
      <a href={BOOK_HREF} class="hidden sm:inline-flex items-center rounded-full bg-clay hover:bg-claydk transition text-white text-sm font-semibold px-5 py-2.5">Book a Consultation</a>
      <button id="menuBtn" class="lg:hidden p-2 -mr-2 text-ever" aria-label="Open menu" aria-controls="drawer" aria-expanded="false">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none"><path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile drawer -->
<div id="drawer" class="fixed inset-0 z-[60] hidden lg:hidden" role="dialog" aria-modal="true">
  <div id="drawerBg" class="absolute inset-0 bg-ink/40 backdrop-blur-sm"></div>
  <aside class="absolute right-0 top-0 h-full w-[88%] max-w-sm bg-cream shadow-2xl flex flex-col translate-x-full transition-transform duration-300 ease-out" id="drawerPanel">
    <div class="flex items-center justify-between px-5 h-16 border-b border-sand">
      <Brand class="text-2xl" />
      <button id="closeBtn" class="p-2 text-ever" aria-label="Close menu">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </button>
    </div>
    <nav class="flex-1 overflow-y-auto px-3 py-4">
      <a href="/" class="block px-3 py-3 font-medium">Home</a>
      {nav.map((section) => (
        <details class="border-b border-sand">
          <summary class="flex justify-between items-center px-3 py-3 font-medium cursor-pointer list-none">
            {section.label}<span class="text-clay">+</span>
          </summary>
          {section.children.map((child) => (
            <a href={child.href} class="block pl-6 pr-3 py-2.5 text-stone hover:text-clay">{child.label}</a>
          ))}
        </details>
      ))}
      <a href="/book" class="block px-3 py-3 font-medium">The Book</a>
      <a href="/contact" class="block px-3 py-3 font-medium">Contact Us</a>
    </nav>
    <div class="p-4 border-t border-sand">
      <a href={BOOK_HREF} class="block text-center rounded-full bg-clay text-white font-semibold px-5 py-3.5">Book a Consultation</a>
    </div>
  </aside>
</div>

<script>
  const drawer = document.getElementById('drawer');
  const panel = document.getElementById('drawerPanel');
  const menuBtn = document.getElementById('menuBtn');
  const open = () => {
    drawer?.classList.remove('hidden');
    requestAnimationFrame(() => panel?.classList.remove('translate-x-full'));
    menuBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };
  const close = () => {
    panel?.classList.add('translate-x-full');
    menuBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    setTimeout(() => drawer?.classList.add('hidden'), 300);
  };
  menuBtn?.addEventListener('click', open);
  document.getElementById('closeBtn')?.addEventListener('click', close);
  document.getElementById('drawerBg')?.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
</script>
