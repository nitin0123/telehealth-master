---
// Self-hosted fonts (bundled into the build, no external requests):
import '@fontsource-variable/geist'; // single typeface — body, UI and headings
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import { SITE, organizationSchema } from '../data/seo';

// Google Search Console ownership verification (meta-tag method).
const gscToken = import.meta.env.PUBLIC_GSC_VERIFICATION || '';
// Meta (Facebook) domain verification for ad campaigns (Business Settings →
// Brand Safety → Domains → Meta-tag method).
const fbDomainToken = import.meta.env.PUBLIC_META_DOMAIN_VERIFICATION || '';

interface Props {
  title?: string;
  description?: string;
  /** Comma-separated keyword string for this page */
  keywords?: string;
  /** Open Graph image path (defaults to the brand image) */
  image?: string;
  /** Set true for pre-launch / utility pages that should not be indexed */
  noindex?: boolean;
  /** og:type, e.g. "website" or "article" */
  ogType?: string;
}
const {
  title = SITE.defaultTitle,
  description = SITE.defaultDescription,
  keywords,
  image = SITE.ogImage,
  noindex = false,
  ogType = 'website',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.url).href;
const ogImage = new URL(image, SITE.url).href;
const robots = noindex ? 'noindex, nofollow' : 'index, follow';
---

<!doctype html>
<html lang="en-IN" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content={robots} />
    {gscToken && <meta name="google-site-verification" content={gscToken} />}
    {fbDomainToken && <meta name="facebook-domain-verification" content={fbDomainToken} />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {image === SITE.ogImage && (
      <>
        <!-- Dimensions let WhatsApp/Facebook render the card on the very first share -->
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:type" content="image/jpeg" />
        <meta property="og:image:alt" content="ResetWell Plus: India's expert-led menopause and perimenopause care" />
      </>
    )}
    <meta property="og:locale" content={SITE.locale} />
    {SITE.altLocales.map((l) => <meta property="og:locale:alternate" content={l} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.twitter} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Site-wide structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <!-- Page-specific structured data (breadcrumbs, FAQ, etc.) -->
    <slot name="head" />

    <script is:inline>
      // Swap no-js -> js as early as possible so reveal styles can animate.
      document.documentElement.classList.remove('no-js');
    </script>
  </head>
  <body>
    <!-- Ambient brand-glow background (soft multi-hue blobs), shown on every page -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute -top-40 -left-32 w-[34rem] h-[34rem] rounded-full bg-peach/50 blur-3xl"></div>
      <div class="absolute top-1/4 -right-40 w-[36rem] h-[36rem] rounded-full bg-sage/40 blur-3xl"></div>
      <div class="absolute bottom-[-10rem] left-1/4 w-[30rem] h-[30rem] rounded-full bg-clay/10 blur-3xl"></div>
    </div>

    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <Analytics />

    <!-- Floating WhatsApp button, shown site-wide. The number is picked at
         random between the two founders on first visit (then remembered on
         the device) and is base64-encoded so scrapers reading the raw HTML
         don't harvest it. -->
    <a
      data-wa-float
      href="/contact"
      target="_blank"
      rel="noopener"
      aria-label="Chat with us on WhatsApp"
      class="fixed bottom-5 right-5 z-40 inline-flex items-center gap-2 rounded-full bg-[#25D366] hover:bg-[#1da851] text-white font-semibold shadow-lg shadow-ever/25 px-4 py-3.5 sm:px-5 transition-all duration-200 hover:-translate-y-0.5"
    >
      <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="hidden sm:inline">WhatsApp</span>
    </a>
    <script is:inline>
      (function () {
        // Founders' WhatsApp numbers (digits only), base64-encoded.
        var encoded = ['MTIwMTI4MjgxNDM=', 'MTczMjc3MTY1NzU='];
        var KEY = 'rwp-wa';
        var idx = null;
        try { idx = localStorage.getItem(KEY); } catch (e) {}
        if (idx !== '0' && idx !== '1') {
          idx = String(Math.floor(Math.random() * encoded.length));
          try { localStorage.setItem(KEY, idx); } catch (e) {}
        }
        var number = atob(encoded[Number(idx)]);
        var text = encodeURIComponent("Hi, I'd like to know more about ResetWell Plus.");
        document.querySelectorAll('[data-wa-float]').forEach(function (a) {
          a.setAttribute('href', 'https://wa.me/' + number + '?text=' + text);
        });
      })();
    </script>

    <!-- Tasteful scroll-reveal: progressive enhancement via IntersectionObserver -->
    <script>
      const els = document.querySelectorAll<HTMLElement>('.reveal');
      if (!('IntersectionObserver' in window) || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        els.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              // Very tall elements (e.g. long legal-text cards) can never reach
              // the 12% ratio, so reveal those as soon as they intersect at all.
              const tall = entry.boundingClientRect.height > window.innerHeight * 0.8;
              if (tall || entry.intersectionRatio >= 0.12) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: [0, 0.12], rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
