# Copy to .env for local dev, and set these in Vercel → Project → Settings →
# Environment Variables (for both the Preview and Production environments).

# --- Postgres (Vercel Postgres / Neon) ---
# The app accepts EITHER of these (set one to your connection string).
# POSTGRES_URL is Vercel's default; DATABASE_URL is also supported.
POSTGRES_URL=
# DATABASE_URL=

# --- Resend (email) ---
# API key from https://resend.com/api-keys
RESEND_API_KEY=

# Where contact-form notifications are sent.
CONTACT_EMAIL_TO=you@example.com

# Sender shown on the notification email. The domain must be verified in your
# Resend account. For quick testing you can use: ResetWell Plus <onboarding@resend.dev>
CONTACT_EMAIL_FROM=ResetWell Plus <noreply@resetwellplus.com>

# --- Analytics (all optional; tracking stays off when unset) ---
# Pages are prerendered, so changing these requires a redeploy to take effect.
# Set them in the Vercel environment where tracking should run (usually only
# Production; add to Preview temporarily if you want to test the banner).

# Google Tag Manager container id (loads only after cookie consent).
PUBLIC_GTM_ID=
# Google Analytics 4 measurement id, loaded directly via gtag.js (only after
# cookie consent). Leave unset if GA4 is instead configured as a tag inside
# the GTM container above, or pageviews will be counted twice.
PUBLIC_GA4_ID=
# Meta (Facebook) Pixel id (loads only after cookie consent).
PUBLIC_META_PIXEL_ID=
# Google Search Console verification token: the content="..." value of the
# meta-tag verification method.
PUBLIC_GSC_VERIFICATION=
